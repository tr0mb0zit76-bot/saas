                    <div class="grid gap-2 rounded-xl border border-zinc-200 p-3 text-sm dark:border-zinc-800 md:grid-cols-5">
                        <div>–†¬¶–†¬Ķ–†–Ö–†¬į –†—Ē–†¬Ľ–†—Ď–†¬Ķ–†–Ö–°‚Äö–†¬į: <span class="font-medium">{{ financialSummary.clientPrice.toFixed(2) }}</span></div>
                        <div>–†–é–†¬Ķ–†¬Ī–†¬Ķ–°–É–°‚Äö–†—ē–†—Ď–†—ė–†—ē–°–É–°‚Äö–°–ä: <span class="font-medium">{{ financialSummary.totalCost.toFixed(2) }}</span></div>
                        <div>–†—ö–†¬į–°–ā–†¬∂–†¬į: <span class="font-medium">{{ financialSummary.margin.toFixed(2) }}</span></div>
                        <div>–†‚ÄĚ–†—ē–†—ó. –°–ā–†¬į–°–É–°‚Ä¶–†—ē–†“Ď–°‚ÄĻ: <span class="font-medium">{{ financialSummary.additionalCosts.toFixed(2) }}</span></div>
                        <div>–†‚Äô–°‚ÄĻ–°‚Ä°–†¬Ķ–°‚Äö: <span class="font-medium">{{ Number(form.financial_term.kpi_percent || 0).toFixed(2) }}%</span></div>
                    </div>

                    <div
