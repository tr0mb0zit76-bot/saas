                    <div class="space-y-2">
                        <div class="flex items-center justify-between gap-3">
                            <label class="text-sm font-medium">–†—ô–†—ē–†–Ö–°‚Äö–°–ā–†¬į–†—Ė–†¬Ķ–†–Ö–°‚Äö</label>
                            <div class="flex flex-wrap items-center gap-2">
                                <CustomerPortalInviteButton
