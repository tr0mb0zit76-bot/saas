# Копия для тестов:  cp .env.testing.example .env.testing
# PHPUnit / php artisan test — ОТДЕЛЬНАЯ БД, не saas_crm (lab).

APP_NAME="Traklo Pro Testing"
APP_ENV=testing
APP_KEY=
APP_DEBUG=true
APP_URL=http://saas.local

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.1.12
DB_PORT=3306
DB_DATABASE=saas_crm_test
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

CRM_DOMAIN=saas.local
SHOWCASE_DOMAIN=saas.local
PLATFORM_DOMAIN=platform.saas.local
SAAS_DEFAULT_TENANT_SLUG=demo

BCRYPT_ROUNDS=4
DOCUMENT_STORAGE=local
ORDER_WIZARD_TEST_DATABASE=saas_crm_test
