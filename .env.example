APP_NAME="Traklo Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Базовый URL приложения (часто совпадает с кабинетом): схема + хост CRM, без завершающего слэша.
# Локально: https://crm.avtoaliyans.local  |  Прод: https://crm.avtoaliyans.ru
# На проде обязательно https://crm.… (иначе Inertia/Ziggy дадут http:// и Mixed Content за прокси).
APP_URL=http://localhost
# FORCE_HTTPS=true

# Разнос по доменам (витрина ≠ кабинет). Nextcloud — отдельный хост, см. NEXTCLOUD_BASE_URL ниже.
#
# | Окружение | Витрина (лендинг)   | Кабинет (CRM)           | Документы (Nextcloud)     |
# |-----------|---------------------|-------------------------|---------------------------|
# | Локально  | avtoaliyans.local   | crm.avtoaliyans.local  | nc.avtoaliyans.local      |
# | Прод      | avtoaliyans.ru      | crm.avtoaliyans.ru      | nc.avtoaliyans.ru         |
# | Прод+www  | avtoaliyans.ru,www.avtoaliyans.ru | crm… | … |
#
# Если витрина и кабинет на одном хосте (только для отладки), задайте CRM_DOMAIN и SHOWCASE_DOMAIN одинаково —
# тогда редирект витрина→кабинет в routes/web.php отключается.
CRM_DOMAIN=crm.avtoaliyans.local
# Витрина: один хост или несколько через запятую. Должен совпадать с реальным Host в браузере.
SHOWCASE_DOMAIN=avtoaliyans.local
# legacy = Avtoaliyans scroll site · traklo_pro = product landing Traklo Pro
SHOWCASE_MODE=traklo_pro

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_TIMEZONE=Europe/Samara
DISPOSITION_TIMEZONE=Europe/Samara

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Витрина: договоры-оферты SLA в public/showcase-sla/*.pdf (не public/documents — конфликт с CRM /documents)
# SHOWCASE_SLA_CUSTOMER_OFFER_PUBLIC=showcase-sla/customer-offer.pdf
# SHOWCASE_SLA_CARRIER_OFFER_PUBLIC=showcase-sla/carrier-offer.pdf
# SHOWCASE_CASES_NAV_VISIBLE=true

# Document storage (local|nextcloud). Локально: https://nc.avtoaliyans.local  |  Прод: https://nc.avtoaliyans.ru
# Traklo Pro SaaS: use tenant S3 (TENANT_STORAGE_DISK=tenant_s3), not Nextcloud — see ADR-005.
DOCUMENT_STORAGE=local
NEXTCLOUD_BASE_URL=
NEXTCLOUD_WEBDAV_USER=
NEXTCLOUD_WEBDAV_PASSWORD=
NEXTCLOUD_WEBDAV_ROOT=/remote.php/dav/files/crm-bot/CRM/Documents
NEXTCLOUD_TIMEOUT=30
# NEXTCLOUD_VERIFY_SSL=false

# ГИС ЭПД / оператор ИС ЭПД (заполняется после договора и выдачи доступа к API).
# План в CRM: АО «Калуга Астрал» — см. config/epd.php → planned_operator.
# EPD_OPERATOR_DRIVER=null
# EPD_OPERATOR_BASE_URL=
# EPD_OPERATOR_WEBHOOK_SECRET=
# EPD_1C_FRESH_TOKEN=

# Загрузка документов: максимальный размер ≈ (оценка страниц) × DOCUMENT_BYTES_PER_PAGE (байт; по умолчанию 600 КиБ).
# На проде выставьте post_max_size / upload_max_filesize в php.ini не ниже ceil(DOCUMENT_MAX_PAGES_CAP × DOCUMENT_BYTES_PER_PAGE / 1024 / 1024) МБ + запас.
# DOCUMENT_BYTES_PER_PAGE=614400
# DOCUMENT_MAX_PAGES_CAP=200
# DOCUMENT_FALLBACK_PAGES_UNKNOWN=12
# DOCUMENT_IMAGE_PLACEHOLDER_PAGES=18

# DOCX preview: use Gotenberg for PDF in browser (needed for stamp/signature overlay alignment).
# If DOC_PREVIEW_DRIVER is omitted or empty and GOTENBERG_URL is set, gotenberg is used automatically.
DOC_PREVIEW_DRIVER=gotenberg
GOTENBERG_URL=http://127.0.0.1:3000
GOTENBERG_TIMEOUT=60

# PDF DocMDP (защита от правки после «подписания» в CRM; не юридическая КЭП).
# php artisan pdf-signing:generate-certificate
# PDF_CERTIFY_ENABLED=true
# PDF_CERTIFY_CERT_PATH=

# Traklo Android APK updates (sideload distribution).
# Main source: public/downloads/traklo-update.json generated by `npm run traklo:apk:debug|release`.
# These env values are emergency overrides only.
# MOBILE_APP_FORCE_CONFIG=false
# MOBILE_APP_MANIFEST_PATH=
# MOBILE_APP_LATEST_VERSION_CODE=1
# MOBILE_APP_LATEST_VERSION_NAME=1.0
# MOBILE_APP_MIN_SUPPORTED_VERSION_CODE=1
# MOBILE_APP_APK_URL=/downloads/traklo.apk
# MOBILE_APP_CHANGELOG="Доступна новая версия Traklo."
# PDF_CERTIFY_KEY_PATH=
# PDF_CERTIFY_DOC_MDP=2

# Order intake OCR (локальный sidecar deploy/ocr)
# Прод: docs/order-intake-ocr-production.md
# ORDER_INTAKE_OCR=local
# OCR_SERVICE_URL=http://127.0.0.1:3001
# OCR_SERVICE_TIMEOUT=120
# DOCUMENT_OPTIMIZE_ENABLED=true

# --- Рабочая локальная БД (разработка в браузере) ---
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=
#
# Windows / OSPanel: `php artisan migrate` на пустой MySQL вызывает mysql.exe для database/schema/mysql-schema.sql.
# Если mysql не в PATH — `composer run migrate` или:
#   php artisan migrate --schema-path=database/schema/.skip-mysql-cli-load
# Либо добавьте в PATH папку bin MySQL из OSPanel (например modules/database/MySQL-8.4/bin).

# --- PHPUnit / `php artisan test` ---
# При запуске тестов APP_ENV=testing, Laravel загружает файл `.env.testing` (он в .gitignore).
# Там должна быть ОТДЕЛЬНАЯ база (например u_tromb_test), чтобы миграции и тесты не трогали
# данные из этого .env. Шаблон: скопируйте `u_tromb.env.example` → `.env.testing`, задайте APP_KEY и доступ к MySQL.

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Lab HTTP: false — иначе trustProxies + X-Forwarded-Proto: https ставит Secure на cookie → 419
SESSION_SECURE_COOKIE=false

# Phase 4 — security headers (enable CSP in production)
SECURITY_HEADERS_CSP_ENABLED=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MAIL_SYNC_ENABLED=true
MAIL_SYNC_IMAP_HOST=mail.example.com
MAIL_SYNC_IMAP_PORT=993
MAIL_SYNC_IMAP_ENCRYPTION=ssl
MAIL_SYNC_IMAP_INBOX_FOLDERS=INBOX
MAIL_SYNC_IMAP_SENT_FOLDERS=Sent
MAIL_SYNC_INITIAL_DAYS=30
MAIL_SYNC_MAX_MESSAGES=200
MAIL_SYNC_INCREMENTAL_OVERLAP_HOURS=24
MAIL_SYNC_MAILBOX_DOMAINS=avtoaliyans.ru
MAIL_SYNC_REQUIRE_CONTRACTOR_MATCH=false
# Вложения: false = lazy (метаданные при sync, файл по «Скачать»). true = качать всё при sync (больше места).
MAIL_SYNC_IMPORT_ATTACHMENTS=false
# MAIL_SYNC_INBOUND_MAX_ATTACHMENTS=10
# MAIL_SYNC_INBOUND_MAX_ATTACHMENT_KB=15360
# MAIL_SYNC_IMPORT_HTML=true
# MAIL_SYNC_MAX_HTML_CHARS=200000

# --- Почта: хранение и AI-конспект (ADR-013) ---
# «Золотая середина»: текст письма храним для анализа; тела старше порога — purge + короткий конспект для AI/CRM.
# Вложения по умолчанию lazy (см. MAIL_SYNC_IMPORT_ATTACHMENTS).
#
# | Параметр | Lab | Prod (рекомендация) | Зачем |
# |----------|-----|---------------------|-------|
# | PURGE_MONTHS | 6 | 6 | Срок до очистки тела (важные письма не трогаем) |
# | SUMMARY_MAX_CHARS | 800 | 800 | Конспект в карточке: 2–4 предложения, не простыня |
# | AI_INPUT_MAX_CHARS | 4000 | 6000 | Сколько текста отдать LLM при purge (~1–2 стр. vs длинная цепочка) |
# | AI_MAX_TOKENS | 320 | 384 | Ответ модели: хватает на русский конспект без воды |
#
MAIL_RETENTION_PURGE_MONTHS=6
MAIL_RETENTION_AI_SUMMARY=true
MAIL_RETENTION_SUMMARY_MAX_CHARS=800
MAIL_RETENTION_AI_INPUT_MAX_CHARS=4000
AI_MAIL_RETENTION_MAX_TOKENS=320
AI_MAIL_RETENTION_TEMPERATURE=0.2
# On-demand анализ цепочек (кнопки в модуле «Почта») — отдельный лимит, щедрее purge:
# AI_MAIL_ANALYSIS_MAX_TOKENS=1200
# AI_MAIL_ANALYSIS_TEMPERATURE=0.3
# AI_INSIGHT_DRAFTS_AUTO_EXTRACT=false

# Traklo Pro — tenant files (ADR-005). Lab: tenant_local. Prod: tenant_s3 (Yandex Object Storage / S3).
TENANT_STORAGE_DISK=tenant_local
TENANT_STORAGE_FOR_DOCUMENTS=true
SAAS_DEFAULT_TENANT_SLUG=demo
SAAS_PLATFORM_ADMIN_EMAILS=admin@saas.local,platform-admin@saas.local
SAAS_TRIAL_DAYS=14
# Public demo signup (trial Start plan). Lab: true. Prod: false until sales process ready.
SAAS_DEMO_SIGNUP_ENABLED=true
# Platform operator portal (super-admin). Локально: platform.saas.local (vhost в OSPanel).
PLATFORM_DOMAIN=platform.saas.local
# TENANT_STORAGE_ROOT_PREFIX=traklo-pro-prod
# TENANT_STORAGE_DISK=tenant_s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ru-central1
AWS_BUCKET=
AWS_ENDPOINT=https://storage.yandexcloud.net
AWS_USE_PATH_STYLE_ENDPOINT=true

VITE_APP_NAME="${APP_NAME}"
# Суффикс заголовка вкладки (витрина / CRM): SHOWCASE_BROWSER_TITLE и CRM_BROWSER_TITLE в config/app.php; значение уходит в Inertia как document_title_suffix. Витрина: SHOWCASE_CHECKO_COMPANY_URL — ссылка виджета Чекко. VITE_APP_NAME на title не влияет. При `npm run build` Vite по-прежнему подхватывает .env с сервера/CI.

# SHOWCASE_CHECKO_COMPANY_URL="https://checko.ru/company/avtoalyans-smolensk-1156733014899"
# SHOWCASE_BROWSER_TITLE="Автоальянс Смоленск"
# CRM_BROWSER_TITLE="CRM компании Автоальянс Смоленск"

# MCP (Cursor / внешние агенты): Bearer-токен Sanctum. Выпуск: php artisan mcp:issue-token --user-id=1
# URL не секрет — прописывается в ~/.cursor/mcp.json на рабочей машине (см. docs/mcp-issue-token.md):
#   локально:  http://v5.local/mcp/crm
#   prod:      https://crm.avtoaliyans.ru/mcp/crm
# MCP_PUBLIC_URL=https://crm.avtoaliyans.ru/mcp/crm
# MCP_DEV_USER_ID=1
# Локальный stdio: php artisan mcp:start crm (без токена, только если задан MCP_DEV_USER_ID)

# Checko.ru API v2 (скоринг контрагента; ключ не коммитить)
CHECKO_API_KEY=
CHECKO_API_BASE=https://api.checko.ru/v2
# CHECKO_CACHE_TTL=86400
# CHECKO_TIMEOUT=20
